# InduForm Environment Configuration
# Copy to .env and adjust values for your deployment.

# --- Server ---
# INDUFORM_ENV=production              # Set to "production" to enable HSTS
# INDUFORM_LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR
# INDUFORM_CONFIG=/config/induform.yaml

# --- Database ---
# INDUFORM_DB=induform.db              # SQLite file path (default)
# INDUFORM_DB=postgresql+asyncpg://user:pass@host/dbname  # PostgreSQL
# INDUFORM_DB_POOL_SIZE=5              # PostgreSQL connection pool size
# INDUFORM_DB_MAX_OVERFLOW=10          # PostgreSQL max overflow connections

# --- Seed Admin (first startup only, when no users exist) ---
# INDUFORM_ADMIN_USERNAME=admin
# INDUFORM_ADMIN_EMAIL=admin@induform.local
# INDUFORM_ADMIN_PASSWORD=admin        # CHANGE THIS before deploying!

# --- Security ---
# INDUFORM_JWT_SECRET=                 # REQUIRED in production — random 32+ char string
# INDUFORM_CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:8081
# INDUFORM_RATE_LIMIT_ENABLED=true     # Set to "false" to disable rate limiting (tests)
# INDUFORM_MAX_BODY_SIZE=10485760      # Max request body in bytes (default 10MB)

# --- External APIs ---
# INDUFORM_NVD_API_KEY=                # NVD API key for higher CVE lookup rate limits

# --- Docker Compose ---
# INDUFORM_PORT=8081                   # Host port mapping
# VITE_PORT=5173                       # Dev mode Vite port mapping
